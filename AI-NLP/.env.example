# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.1
OPENAI_MAX_TOKENS=1500

# Embedding
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
USE_MOCK_DATA=true
LOG_LEVEL=INFO

# Backend Integration (future)
BACKEND_API_URL=http://localhost:5000/api
BACKEND_API_KEY=

# CV Analysis
CV_PASS_THRESHOLD=85
CV_UPLOAD_DIR=./data/uploads
CV_MAX_UPLOAD_SIZE_MB=10

# Test Configuration
TECHNICAL_TEST_QUESTION_COUNT=10
TECHNICAL_TEST_TIME_LIMIT_MINUTES=30
ENGLISH_TEST_QUESTION_COUNT=10
ENGLISH_TEST_TIME_LIMIT_MINUTES=25
